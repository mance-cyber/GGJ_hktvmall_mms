# =============================================
# GoGoJap - 環境變量模板
# =============================================
# 複製為 .env 並填入實際值：
#   cp .env.template .env && nano .env
# =============================================

# ==================== 應用 ====================
APP_ENV=production
DEBUG=false
SECRET_KEY=<生成: python3 -c "import secrets; print(secrets.token_urlsafe(48))">

# ==================== 數據庫 (Neon) ====================
DATABASE_URL=postgresql+asyncpg://<user>:<password>@<host>.neon.tech/<db>?sslmode=require

# ==================== AI ====================
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929

# ==================== 抓取 ====================
FIRECRAWL_API_KEY=fc-...
AGENT_BROWSER_ENABLED=true

# ==================== 存儲 (R2/S3) ====================
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_BUCKET=
R2_ENDPOINT=

# ==================== 域名 (可選) ====================
# GOGOJAP_DOMAIN=api.gogojap.com
